<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SPEEDHUB</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <nav class="navbar">
        <div class="logo">
            SPEED<span>HUB</span>
        </div>

        <ul class="nav-links">
            <li><a href="#">Home</a></li>
            <li><a href="#">Buy Data</a></li>
            <li><a href="#">Pricing</a></li>
            <li><a href="#">Contact</a></li>
        </ul>

        <div class="buttons">
            <a href="#" class="login">Login</a>
            <a href="#" class="register">Register</a>
        </div>
    </nav>
<section class="hero">

    <div class="hero-content">

        <h1>
            Affordable Data Bundles
            <span>Across Ghana</span>
        </h1>

        <p>
            Buy MTN, Telecel, and AT data bundles instantly.
            Fast delivery, secure payments, and 24/7 support.
        </p>

        <div class="hero-buttons">
            <a href="#" class="buy-btn">Buy Data</a>
            <a href="#" class="create-btn">Create Account</a>
        </div>

    </div>

</section>
<section class="features">

    <div class="feature-card">
        <div class="icon">⚡</div>
        <h2>Instant Delivery</h2>
        <p>
            Receive your data bundle within seconds after payment.
        </p>
    </div>

    <div class="feature-card">
        <div class="icon">🔒</div>
        <h2>Secure Payment</h2>
        <p>
            Pay confidently using our secure payment system.
        </p>
    </div>

    <div class="feature-card">
        <div class="icon">🎧</div>
        <h2>24/7 Support</h2>
        <p>
            Our support team is available whenever you need help.
        </p>
    </div>

</section>
<section class="networks">

    <h2 class="section-title">Choose Your Network</h2>

    <div class="network-container">

        <div class="network-card mtn">
            <h3>🟡 MTN</h3>
            <p>Fast and affordable MTN data bundles.</p>
            <a href="#" class="network-btn">Buy MTN Data</a>
        </div>

        <div class="network-card telecel">
            <h3>🔴 Telecel</h3>
            <p>Reliable Telecel data bundles at great prices.</p>
            <a href="#" class="network-btn">Buy Telecel Data</a>
        </div>

        <div class="network-card at">
            <h3>🔵 AT</h3>
            <p>Instant AT data delivery anytime you need it.</p>
            <a href="#" class="network-btn">Buy AT Data</a>
        </div>

    </div>

</section>
</body>
</html>